# Configuración de Modelo
MODEL_SIZE=n          # n, s, m, l, x (s recomendado)
DEVICE=cpu            # cpu, cuda, mps
CONFIDENCE_THRESHOLD=0.5

# Umbral de Anomalías
CROWD_THRESHOLD=5
LOITER_THRESHOLD=10.0

# Configuración de Servidor
HOST=0.0.0.0
PORT=8000
DEBUG=false
RELOAD=false

LOG_LEVEL=INFO
ENABLE_EMAIL_ALERTS=false